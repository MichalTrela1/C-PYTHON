using System;

namespace zadanie2
{
    class Program
    {
        static void Main(string[] args)
        {
            Console.Write("Co chcesz przekonwertować? Celsjusz na Fahrenheit - wpisz C, jeśli odwrotnie - wpisz F! ");
                string konwert = Console.ReadLine().ToUpper();

            Console.Write("Podaj temperaturę: ");
                double temperatura = Convert.ToDouble(Console.ReadLine());

            if (konwert == "C")
            {
                double fahrenheit = temperatura * 1.8 + 32;
                    Console.WriteLine($"{temperatura}°C = {fahrenheit}°F");
            }
                else if (konwert == "F")
            {
                double celsjusz = (temperatura - 32) / 1.8;
                    Console.WriteLine($"{temperatura} °F = {celsjusz}°C");
                
            }
            Console.WriteLine("Koniec.");
        }
    }
}
