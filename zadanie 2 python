konwert = input("Co chcesz przekonwertować? Celsjusz na Fahrenheit - wpisz C, jeśli odwrotnie - wpisz F! ").upper()

temperatura = float(input("Podaj temperaturę: "))

if konwert == "C":
    
    fahrenheit = temperatura * 1.8 + 32
    print(f"{temperatura}°C = {fahrenheit}°F ")

elif konwert == "F":
    
    celsjusz = (temperatura - 32) / 1.8
    print(f"{temperatura}°F = {celsjusz}°C")


print("Koniec.")
