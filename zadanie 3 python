liczba_ocen = int(input("Podaj liczbę ocen: "))

suma = 0.0

for i in range(liczba_ocen):
    ocena = float(input(f"Podaj ocenę {i + 1} od 1 do 6: "))
    suma += ocena
    
if liczba_ocen > 0:
    srednia = suma / liczba_ocen

    print(f"Średnia: {srednia:.2f}")

 
    if srednia >= 3.0:
        print("Uczeń zdal ")
    else:
        print("Uczen niestety nie zdal ")
else:
    print("Niepoprawne dane, nie mozna obliczyc sredniej wazonej")
